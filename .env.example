# ============================================================
# parking-fraud-system 环境变量模板
# 复制为 .env 后按需修改
# ============================================================

# ── 后端服务 ────────────────────────────────────────────────
PORT=3000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123
JWT_EXPIRES_IN=2h

# ── Redis ───────────────────────────────────────────────────
# 以下为 Docker 内部地址（容器间通信用），宿主机测试脚本用 127.0.0.1
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=Admin@123
# 宿主机连接 Redis 的外部地址（可选，默认 127.0.0.1:6379）
# REDIS_EXTERNAL_HOST=127.0.0.1
# REDIS_EXTERNAL_PORT=6379

# ── MySQL 8.0 ───────────────────────────────────────────────
# 以下为 Docker 内部地址（容器间通信用），宿主机测试脚本用 127.0.0.1:3307
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=parking
MYSQL_ROOT_PASSWORD=Admin@123
MYSQL_DATABASE=parking_fraud
# 宿主机连接 MySQL 的外部地址（docker-compose 映射 3307:3306，默认 127.0.0.1:3307）
# MYSQL_EXTERNAL_HOST=127.0.0.1
# MYSQL_EXTERNAL_PORT=3307

# ── 加密密钥 ────────────────────────────────────────────────
ENCRYPT_KEY=123456789101112131415161718192021222324252627282930313233343536
